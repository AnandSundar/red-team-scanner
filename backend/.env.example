# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/redteam?sslmode=disable

# Redis
REDIS_URL=localhost:6379

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo-preview

# Server
PORT=8080
ENV=development

# Security
API_KEY_SECRET=your-api-key-secret
JWT_SECRET=your-jwt-secret

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Stripe Billing (Phase 16)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_TEAM=price_...

# App URL (for Stripe redirects)
APP_URL=http://localhost:3000

# Threat Intelligence APIs (Optional)
ABUSEIPDB_API_KEY=your-abuseipdb-api-key  # Get from https://www.abuseipdb.com/api.html
# NVD API is free and unauthenticated (rate limited to 5 req/30s)
# Shodan InternetDB is free and unauthenticated
# URLhaus is free and unauthenticated
# Certificate Transparency (crt.sh) is free and unauthenticated
