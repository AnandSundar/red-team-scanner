# =============================================================================
# Red Team Scanner Frontend - Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# URL of the backend API service
NEXT_PUBLIC_API_URL=http://localhost:8080
API_URL=http://localhost:8080

# API timeout in milliseconds
NEXT_PUBLIC_API_TIMEOUT=30000

# -----------------------------------------------------------------------------
# Clerk Authentication (Required)
# -----------------------------------------------------------------------------
# Get these from your Clerk Dashboard: https://dashboard.clerk.dev
# Sign up/in URLs are configured in your Clerk Dashboard

# Publishable Key (safe to expose on client)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Secret Key (server-side only)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Sign-in/Sign-up URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Post-auth redirects
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# -----------------------------------------------------------------------------
# Stripe Configuration (Required for billing)
# -----------------------------------------------------------------------------
# Get these from your Stripe Dashboard: https://dashboard.stripe.com

# Publishable Key (client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Price IDs for subscription plans
NEXT_PUBLIC_STRIPE_PRICE_BASIC=price_basic_plan_id_here
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_pro_plan_id_here
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE=price_enterprise_plan_id_here

# Stripe Webhook Secret (server-side)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# App name shown in UI
NEXT_PUBLIC_APP_NAME="Agentic Red Team Scanner"

# Public URL of the application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# App version (shown in footer)
NEXT_PUBLIC_APP_VERSION=1.0.0

# Support email
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FEATURE_AI_SCANNING=true
NEXT_PUBLIC_FEATURE_PDF_EXPORT=true
NEXT_PUBLIC_FEATURE_TEAM_MANAGEMENT=true
NEXT_PUBLIC_FEATURE_WEBHOOKS=true

# -----------------------------------------------------------------------------
# Analytics (Optional)
# -----------------------------------------------------------------------------
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# PostHog API Key
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------
# Sentry DSN for error tracking
NEXT_PUBLIC_SENTRY_DSN=

# LogRocket App ID for session replay
NEXT_PUBLIC_LOGROCKET_APP_ID=

# -----------------------------------------------------------------------------
# Development Settings
# -----------------------------------------------------------------------------
# Enable React Strict Mode
NEXT_PUBLIC_STRICT_MODE=true

# Enable MSW (Mock Service Worker) for API mocking
NEXT_PUBLIC_MOCK_API=false

# Disable telemetry in development
NEXT_TELEMETRY_DISABLED=1
